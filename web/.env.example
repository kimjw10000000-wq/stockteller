# 관리자 로그인 (/admin) — Supabase Auth 계정 이메일 (쉼표로 여러 명 가능, .env.local·Vercel에만 설정)
ADMIN_EMAILS=your-admin@example.com

# 유료 회원 이메일 (쉼표 구분) — Supabase Auth 로그인 시 유료 콘텐츠 열람
PREMIUM_EMAILS=premium-user@example.com

GEMINI_API_KEY=your_gemini_api_key
# Google AI Studio — 기본은 gemini-3-flash-preview (analyzeDisclosure.ts와 동일)
GEMINI_MODEL=gemini-3-flash-preview

# SEC fair access: https://www.sec.gov/os/webmaster-faq#code-support
SEC_USER_AGENT=YourProject/1.0 (you@example.com)

# 공개 사이트 URL (SEO: metadataBase, OG, sitemap). 예: https://whyup.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Used by GitHub Actions / local crawler only (optional for Next runtime)
SITE_URL=https://your-deployment.vercel.app

# ========== 글로벌 시세 엔진 (npm run engine) ==========
# /api/us-day-gainers: Yahoo 후보 종목의 등락률·가격을 Finnhub /quote로 맞출 때도 사용(웹소켓 엔진과 동일 키).
FINNHUB_API_KEY=
ENGINE_US_SYMBOLS=AAPL,NVDA,TSLA
ENGINE_US_THRESHOLD_PCT=20

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_MODE=real

ENGINE_KR_CODES=005930,000660
ENGINE_KR_PREV_CLOSE_JSON=
ENGINE_KR_THRESHOLD_PCT=15

JQUANTS_MAIL=
JQUANTS_PASSWORD=
ENGINE_JP_CODES=72030
ENGINE_JP_POLL_MS=30000
ENGINE_JP_THRESHOLD_PCT=15

ENGINE_UPSERT_MIN_MS=15000

# Vercel 등에서 Yahoo 서버 요청이 막힐 때 미국 급등 폴백 (https://www.alphavantage.co/support/#api-key)
# Vercel 대시보드에도 동일 이름으로 추가(Production 체크) 후 Redeploy
ALPHA_VANTAGE_API_KEY= PXX2X1PAQHPILWKL
