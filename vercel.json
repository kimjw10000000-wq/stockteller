{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --prefix web",
  "buildCommand": "npm run build --prefix web",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.whyup.net" }],
      "destination": "https://whyup.net/:path*",
      "permanent": true
    }
  ]
}
